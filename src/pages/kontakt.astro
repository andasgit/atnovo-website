---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontakt" description="Kostenlose Erstberatung bei atNOVO GmbH. Schreib uns oder ruf an – wir melden uns innerhalb von 24 Stunden.">

  <section class="py-20 lg:py-28 bg-[#F7F9FC] min-h-[80vh]">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-14 items-start">

        <!-- Left: Info -->
        <div class="fade-up">
          <p class="text-xs font-semibold text-[#00956E] uppercase tracking-widest mb-4">Kontakt aufnehmen</p>
          <h1 class="font-display text-5xl lg:text-6xl font-extrabold text-[#0C1628] tracking-tight leading-tight mb-6">
            Lass uns reden.
          </h1>
          <p class="text-lg text-[#4B5563] leading-relaxed mb-10">
            Das erste Gespräch ist kostenlos und unverbindlich. Wir hören zu, verstehen dein Business und sagen dir ehrlich, was wir für dich tun können.
          </p>

          <div class="space-y-5">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-[#0C1628] rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-[#00C896]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-[#0C1628]">E-Mail</p>
                <a href="mailto:info@atnovo.com" class="text-sm text-[#4B5563] hover:text-[#00956E] transition-colors">info@atnovo.com</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-[#0C1628] rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-[#00C896]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-[#0C1628]">Telefon</p>
                <a href="tel:+494060778174" class="text-sm text-[#4B5563] hover:text-[#00956E] transition-colors">+49 (0) 40 60778174</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-[#0C1628] rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-[#00C896]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-[#0C1628]">Antwortzeit</p>
                <p class="text-sm text-[#4B5563]">Innerhalb von 24 Stunden</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-[#0C1628] rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-[#00C896]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-[#0C1628]">Erstgespräch</p>
                <p class="text-sm text-[#4B5563]">Kostenlos & unverbindlich</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="fade-up delay-2 bg-white rounded-3xl p-8 lg:p-10 border border-gray-100 shadow-sm">
          <h2 class="font-display text-2xl font-bold text-[#0C1628] mb-7">Schreib uns eine Nachricht.</h2>

          <form class="space-y-5" action="#" method="POST">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-xs font-semibold text-[#374151] mb-1.5" for="name">Dein Name *</label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  required
                  placeholder="Max Mustermann"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-[#F7F9FC] text-sm text-[#0D1117] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#00C896]/30 focus:border-[#00C896] transition-colors"
                />
              </div>
              <div>
                <label class="block text-xs font-semibold text-[#374151] mb-1.5" for="email">E-Mail-Adresse *</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  placeholder="max@deinbusiness.de"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-[#F7F9FC] text-sm text-[#0D1117] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#00C896]/30 focus:border-[#00C896] transition-colors"
                />
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold text-[#374151] mb-1.5" for="bereich">Worum geht es? *</label>
              <select
                id="bereich"
                name="bereich"
                required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-[#F7F9FC] text-sm text-[#0D1117] focus:outline-none focus:ring-2 focus:ring-[#00C896]/30 focus:border-[#00C896] transition-colors"
              >
                <option value="" disabled selected>Bitte auswählen …</option>
                <option>Website-Erstellung</option>
                <option>KI-Assistent / Chatbot</option>
                <option>KI-Telefonie / Voicebot</option>
                <option>Online-Terminbuchung</option>
                <option>SEO</option>
                <option>Google Ads (SEA)</option>
                <option>Social Media</option>
                <option>Online Marketing</option>
                <option>Allgemeine Beratung</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-semibold text-[#374151] mb-1.5" for="nachricht">Deine Nachricht *</label>
              <textarea
                id="nachricht"
                name="nachricht"
                required
                rows="5"
                placeholder="Erzähl uns kurz von deinem Business und was du dir vorstellst …"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-[#F7F9FC] text-sm text-[#0D1117] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#00C896]/30 focus:border-[#00C896] transition-colors resize-none"
              ></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input id="datenschutz" name="datenschutz" type="checkbox" required class="mt-0.5 w-4 h-4 accent-[#00C896]" />
              <label for="datenschutz" class="text-xs text-[#6B7280] leading-relaxed">
                Ich habe die <a href="/datenschutz" class="text-[#00956E] hover:underline">Datenschutzerklärung</a> gelesen und bin mit der Verarbeitung meiner Daten einverstanden. *
              </label>
            </div>

            <button
              type="submit"
              class="w-full py-4 bg-[#0C1628] text-white font-bold rounded-xl hover:bg-[#1a2d50] transition-all hover:shadow-xl text-sm"
            >
              Nachricht absenden →
            </button>

            <p class="text-xs text-center text-[#9CA3AF]">Wir melden uns innerhalb von 24 Stunden bei dir.</p>
          </form>
        </div>

      </div>
    </div>
  </section>

</Layout>
