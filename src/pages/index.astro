---
import Layout from '../layouts/Layout.astro';
---

<Layout title="atNOVO GmbH" description="Digitale Lösungen für E-Commerce und Praxen. Wir übernehmen die Technik – du konzentrierst dich auf deine Berufung.">

  <!-- HERO — Full-screen cinematic -->
  <section class="relative h-screen min-h-[600px] flex flex-col justify-end overflow-hidden -mt-16">

    <!-- Background image -->
    <img
      src="/assets/atnovo-hero-people.png"
      alt="Atnovo Beratung"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />

    <!-- Layered overlays: subtle top vignette + heavy bottom gradient -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#071625]/92 via-[#071625]/40 to-[#071625]/10 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#071625]/30 to-transparent pointer-events-none"></div>

    <!-- Content — anchored bottom-left -->
    <div class="relative max-w-7xl mx-auto px-5 lg:px-8 w-full pb-14 lg:pb-20">

      <!-- Label -->
      <div class="fade-up inline-flex items-center gap-2 mb-6">
        <span class="w-8 h-px bg-[#087889]"></span>
        <span class="text-xs font-semibold text-[#76C6C7] uppercase tracking-[0.2em]">Digital Consulting</span>
      </div>

      <!-- Main headline -->
      <h1 class="fade-up delay-1 font-display leading-none tracking-tight mb-6">
        <span class="block text-[clamp(3.5rem,10vw,8.5rem)] leading-[0.92]">
          <span class="font-light text-white/55">at</span><span class="font-extrabold text-white">NOVO</span>
        </span>
        <span class="block text-[clamp(1.6rem,4.5vw,3.8rem)] text-white/60 font-light tracking-[0.06em] mt-3">Digital Consulting</span>
      </h1>

      <!-- Tagline + CTA row -->
      <div class="fade-up delay-2 flex flex-col sm:flex-row sm:items-end gap-6 sm:gap-12">
        <p class="text-base sm:text-lg text-white/60 max-w-sm leading-relaxed">
          Digitale Lösungen, die dein Business voranbringen — ohne Technik-Stress.
        </p>
        <div class="flex gap-3 flex-shrink-0">
          <a href="/kontakt" class="px-6 py-3 bg-[#087889] text-white font-semibold rounded-full hover:bg-[#005F70] transition-all hover:shadow-xl text-sm whitespace-nowrap">
            Jetzt starten →
          </a>
          <a href="/leistungen" class="px-6 py-3 bg-white/10 backdrop-blur-sm text-white font-medium rounded-full hover:bg-white/20 transition-all text-sm border border-white/20 whitespace-nowrap">
            Leistungen
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-6 right-8 hidden lg:flex flex-col items-center gap-2 opacity-40">
      <span class="text-[10px] text-white uppercase tracking-widest" style="writing-mode:vertical-rl">Scroll</span>
      <div class="w-px h-12 bg-white/50 relative overflow-hidden">
        <div class="w-full bg-white animate-[scrollline_1.8s_ease-in-out_infinite]" style="height:40%;animation:scrollline 1.8s ease-in-out infinite"></div>
      </div>
    </div>
  </section>

  <style>
    @keyframes scrollline {
      0%   { transform: translateY(-100%); }
      100% { transform: translateY(250%); }
    }

    /* Service tile hover animation */
    .service-tile {
      position: relative;
      overflow: hidden;
      border-radius: 16px;
      aspect-ratio: 4/3;
    }
    .tile-bg {
      position: absolute;
      inset: 0;
      transition: transform 600ms ease;
    }
    .service-tile:hover .tile-bg {
      transform: scale(1.05);
    }
    .tile-default {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
      padding: 24px;
      text-align: center;
      transition: opacity 300ms ease;
    }
    .service-tile:hover .tile-default {
      opacity: 0;
    }
    .tile-icon-wrap {
      width: 52px;
      height: 52px;
      border-radius: 14px;
      background: rgba(255,255,255,0.10);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .tile-label {
      font-size: 1rem;
      font-weight: 700;
      color: #ffffff;
      letter-spacing: 0.01em;
    }
    .tile-overlay {
      position: absolute;
      inset: 0;
      background: rgba(5, 18, 32, 0.92);
      opacity: 0;
      visibility: hidden;
      transition: opacity 400ms ease, visibility 400ms ease;
    }
    .service-tile:hover .tile-overlay {
      opacity: 1;
      visibility: visible;
    }
    .tile-hover-content {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 22px 24px;
      transform: translateY(18px);
      opacity: 0;
      visibility: hidden;
      transition: transform 650ms ease, opacity 650ms ease, visibility 650ms ease;
    }
    .service-tile:hover .tile-hover-content {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
    }
    .tile-hover-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 6px;
    }
    .tile-hover-desc {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.65);
      line-height: 1.55;
    }
    .tile-accent {
      width: 28px;
      height: 2px;
      background: #087889;
      margin-bottom: 10px;
    }
  </style>

  <!-- POSITIONING — Was wir aufbauen -->
  <section class="bg-[#F7F9FC] py-24">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="fade-up text-center mb-14">
        <p class="text-xs font-semibold text-[#087889] uppercase tracking-widest mb-3">Was wir aufbauen</p>
        <h2 class="font-display text-4xl lg:text-5xl font-bold text-[#0C1628] tracking-tight mb-4">Digital. Strategisch. Wirkungsvoll.</h2>
        <p class="text-[#4B5563] max-w-lg mx-auto">Von der ersten Idee bis zur fertigen Lösung — wir begleiten dich über den gesamten Weg.</p>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">

        <!-- 01 KI & Automatisierung — dark highlight -->
        <div class="fade-up card-lift relative bg-[#0C1628] rounded-3xl p-8 lg:p-10 overflow-hidden">
          <div class="absolute top-0 right-0 w-56 h-56 bg-[#087889]/10 rounded-full -translate-y-1/3 translate-x-1/3 pointer-events-none"></div>
          <div class="relative">
            <span class="text-[#087889]/50 font-display text-5xl font-bold block mb-4 leading-none">01</span>
            <div class="w-12 h-12 bg-[#087889]/15 rounded-2xl flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/>
              </svg>
            </div>
            <p class="text-xs font-semibold text-[#087889] uppercase tracking-widest mb-2">Für alles einsetzbar</p>
            <h3 class="font-display text-2xl font-bold text-white mb-3">KI & Automatisierung</h3>
            <p class="text-[#9CA3AF] leading-relaxed text-sm">Chatbots, Voicebots, Prozessautomatisierung — wir bringen KI dorthin, wo sie deinen Alltag wirklich leichter macht. Nicht als Spielerei, sondern als echtes Werkzeug.</p>
          </div>
        </div>

        <!-- 02 Strategie & Markenbildung — light -->
        <div class="fade-up delay-1 card-lift relative bg-white rounded-3xl p-8 lg:p-10 border border-gray-100 overflow-hidden">
          <div class="absolute bottom-0 right-0 w-40 h-40 bg-[#087889]/5 rounded-full translate-y-1/3 translate-x-1/3 pointer-events-none"></div>
          <div class="relative">
            <span class="text-[#0C1628]/10 font-display text-5xl font-bold block mb-4 leading-none">02</span>
            <div class="w-12 h-12 bg-[#087889]/10 rounded-2xl flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
              </svg>
            </div>
            <p class="text-xs font-semibold text-[#087889] uppercase tracking-widest mb-2">Die Grundlage für alles</p>
            <h3 class="font-display text-2xl font-bold text-[#0C1628] mb-3">Strategie & Markenbildung</h3>
            <p class="text-[#4B5563] leading-relaxed text-sm">Wer bist du, was bietest du, wen willst du erreichen? Wir schärfen deine Positionierung, entwickeln deine Marke und sorgen dafür, dass alles zusammenpasst — bevor es nach außen geht.</p>
          </div>
        </div>

        <!-- 03 App & Software-Entwicklung — light -->
        <div class="fade-up card-lift relative bg-white rounded-3xl p-8 lg:p-10 border border-gray-100 overflow-hidden">
          <div class="absolute top-0 left-0 w-40 h-40 bg-[#087889]/5 rounded-full -translate-y-1/3 -translate-x-1/3 pointer-events-none"></div>
          <div class="relative">
            <span class="text-[#0C1628]/10 font-display text-5xl font-bold block mb-4 leading-none">03</span>
            <div class="w-12 h-12 bg-[#087889]/10 rounded-2xl flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
              </svg>
            </div>
            <p class="text-xs font-semibold text-[#087889] uppercase tracking-widest mb-2">Deine Idee, unser Code</p>
            <h3 class="font-display text-2xl font-bold text-[#0C1628] mb-3">App & Software-Entwicklung</h3>
            <p class="text-[#4B5563] leading-relaxed text-sm">Ob Web-App, Mobile-App oder individuelles Tool — wir bauen, was du brauchst. Modern, skalierbar und so, dass du es selbst in der Hand hast.</p>
          </div>
        </div>

        <!-- 04 Digitale Beratung — teal -->
        <div class="fade-up delay-1 card-lift relative bg-[#087889] rounded-3xl p-8 lg:p-10 overflow-hidden">
          <div class="absolute bottom-0 left-0 w-56 h-56 bg-white/5 rounded-full translate-y-1/3 -translate-x-1/3 pointer-events-none"></div>
          <div class="relative">
            <span class="text-[#0C1628]/20 font-display text-5xl font-bold block mb-4 leading-none">04</span>
            <div class="w-12 h-12 bg-[#0C1628]/15 rounded-2xl flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-[#0C1628]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
              </svg>
            </div>
            <p class="text-xs font-semibold text-[#0C1628]/60 uppercase tracking-widest mb-2">Klarheit statt Verwirrung</p>
            <h3 class="font-display text-2xl font-bold text-[#0C1628] mb-3">Digitale Beratung</h3>
            <p class="text-[#0C1628]/70 leading-relaxed text-sm">Du weißt, dass du digital besser aufgestellt sein musst — aber nicht wie. Wir analysieren, priorisieren und begleiten dich mit einem klaren Plan. Ohne Berater-Sprache, ohne Overhead.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SERVICES OVERVIEW -->
  <section class="py-24 bg-[#F7F9FC]">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="fade-up text-center mb-14">
        <p class="text-xs font-semibold text-[#087889] uppercase tracking-widest mb-3">Was wir tun</p>
        <h2 class="font-display text-4xl lg:text-5xl font-bold text-[#0C1628] tracking-tight mb-4">Alles aus einer Hand.</h2>
        <p class="text-[#4B5563] max-w-xl mx-auto">Kein Wirrwarr aus verschiedenen Anbietern. Wir kümmern uns um alles — von der ersten Idee bis zum laufenden Betrieb.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">

        <!-- Tile 1: KI-Assistent -->
        <div class="fade-up service-tile" id="chatbot">
          <div class="tile-bg" style="background: #0C1628;"></div>
          <div class="tile-default">
            <div class="tile-icon-wrap">
              <svg class="w-6 h-6 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
            </div>
            <span class="tile-label">KI-Assistent</span>
          </div>
          <div class="tile-overlay"></div>
          <div class="tile-hover-content">
            <div class="tile-accent"></div>
            <div class="tile-hover-title">KI-Assistent</div>
            <div class="tile-hover-desc">Dein digitaler Mitarbeiter, der rund um die Uhr Fragen beantwortet, Leads sammelt und Kunden betreut.</div>
          </div>
        </div>

        <!-- Tile 2: KI-Telefonie -->
        <div class="fade-up delay-1 service-tile" id="telefonie">
          <div class="tile-bg" style="background: #0D2B2B;"></div>
          <div class="tile-default">
            <div class="tile-icon-wrap">
              <svg class="w-6 h-6 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <span class="tile-label">KI-Telefonie</span>
          </div>
          <div class="tile-overlay"></div>
          <div class="tile-hover-content">
            <div class="tile-accent"></div>
            <div class="tile-hover-title">KI-Telefonie</div>
            <div class="tile-hover-desc">Dein Telefon nimmt automatisch an — freundlich, kompetent, rund um die Uhr. Voicebot-Technologie, die beeindruckt.</div>
          </div>
        </div>

        <!-- Tile 3: E-Mail -->
        <div class="fade-up delay-2 service-tile">
          <div class="tile-bg" style="background: #18181B;"></div>
          <div class="tile-default">
            <div class="tile-icon-wrap">
              <svg class="w-6 h-6 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <span class="tile-label">Professionelle E-Mail</span>
          </div>
          <div class="tile-overlay"></div>
          <div class="tile-hover-content">
            <div class="tile-accent"></div>
            <div class="tile-hover-title">Professionelle E-Mail</div>
            <div class="tile-hover-desc">Deine eigene Unternehmens-E-Mail-Adresse — seriös, zuverlässig und komplett eingerichtet.</div>
          </div>
        </div>

        <!-- Tile 4: Terminbuchung -->
        <div class="fade-up service-tile" id="termine">
          <div class="tile-bg" style="background: #0F1F30;"></div>
          <div class="tile-default">
            <div class="tile-icon-wrap">
              <svg class="w-6 h-6 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <span class="tile-label">Online-Terminbuchung</span>
          </div>
          <div class="tile-overlay"></div>
          <div class="tile-hover-content">
            <div class="tile-accent"></div>
            <div class="tile-hover-title">Online-Terminbuchung</div>
            <div class="tile-hover-desc">Kunden buchen selbst — tag und nacht. Kein Telefonieren, keine Doppelbuchungen, keine verpassten Anfragen.</div>
          </div>
        </div>

        <!-- Tile 5: Website -->
        <div class="fade-up delay-1 service-tile" id="website">
          <div class="tile-bg" style="background: #071625;"></div>
          <div class="tile-default">
            <div class="tile-icon-wrap">
              <svg class="w-6 h-6 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
              </svg>
            </div>
            <span class="tile-label">Website-Erstellung</span>
          </div>
          <div class="tile-overlay"></div>
          <div class="tile-hover-content">
            <div class="tile-accent"></div>
            <div class="tile-hover-title">Website-Erstellung</div>
            <div class="tile-hover-desc">Dein professionelles digitales Zuhause — modern, schnell und so gebaut, dass Google dich findet.</div>
          </div>
        </div>

        <!-- Tile 6: Online Marketing -->
        <div class="fade-up delay-2 service-tile" id="marketing">
          <div class="tile-bg" style="background: #0C1628;"></div>
          <div class="tile-default">
            <div class="tile-icon-wrap">
              <svg class="w-6 h-6 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/>
              </svg>
            </div>
            <span class="tile-label">Online Marketing</span>
          </div>
          <div class="tile-overlay"></div>
          <div class="tile-hover-content">
            <div class="tile-accent"></div>
            <div class="tile-hover-title">Online Marketing</div>
            <div class="tile-hover-desc">Damit dich die richtigen Menschen finden. Wir sorgen dafür, dass deine Zielgruppe auf dich aufmerksam wird.</div>
          </div>
        </div>

        <!-- Tile 7: Social Media -->
        <div class="fade-up service-tile">
          <div class="tile-bg" style="background: #0D2B2B;"></div>
          <div class="tile-default">
            <div class="tile-icon-wrap">
              <svg class="w-6 h-6 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/>
              </svg>
            </div>
            <span class="tile-label">Social Media</span>
          </div>
          <div class="tile-overlay"></div>
          <div class="tile-hover-content">
            <div class="tile-accent"></div>
            <div class="tile-hover-title">Social Media</div>
            <div class="tile-hover-desc">Deine Präsenz auf Instagram, LinkedIn & Co. — ohne dass du selbst täglich posten musst. Wir liefern.</div>
          </div>
        </div>

        <!-- Tile 8: Google Ads -->
        <div class="fade-up delay-1 service-tile">
          <div class="tile-bg" style="background: #18181B;"></div>
          <div class="tile-default">
            <div class="tile-icon-wrap">
              <svg class="w-6 h-6 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <span class="tile-label">Google Ads (SEA)</span>
          </div>
          <div class="tile-overlay"></div>
          <div class="tile-hover-content">
            <div class="tile-accent"></div>
            <div class="tile-hover-title">Google Ads (SEA)</div>
            <div class="tile-hover-desc">Sofort auf Seite 1 bei Google — genau dann, wenn deine Kunden suchen. Kein Streuverlust, maximale Wirkung.</div>
          </div>
        </div>

        <!-- Tile 9: SEO -->
        <div class="fade-up delay-2 service-tile" id="seo">
          <div class="tile-bg" style="background: #087889;"></div>
          <div class="tile-default">
            <div class="tile-icon-wrap" style="background: rgba(0,0,0,0.15);">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            </div>
            <span class="tile-label">SEO-Agentur</span>
          </div>
          <div class="tile-overlay"></div>
          <div class="tile-hover-content">
            <div class="tile-accent"></div>
            <div class="tile-hover-title">SEO-Agentur</div>
            <div class="tile-hover-desc">Langfristig bei Google gefunden werden — ohne jeden Monat fürs Klicken zu bezahlen. Nachhaltige Sichtbarkeit.</div>
          </div>
        </div>

      </div>

      <div class="fade-up text-center mt-10">
        <a href="/leistungen" class="inline-flex items-center gap-2 text-sm font-semibold text-[#0C1628] border-b-2 border-[#087889] pb-0.5 hover:text-[#087889] transition-colors">
          Alle Leistungen im Detail →
        </a>
      </div>
    </div>
  </section>

  <!-- WIE ES FUNKTIONIERT -->
  <section class="bg-[#0C1628] py-24">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="fade-up text-center mb-16">
