---
import Layout from '../layouts/Layout.astro';
---

<Layout title="atNOVO GmbH" description="Digitale Lösungen für E-Commerce und Praxen. Wir übernehmen die Technik – du konzentrierst dich auf deine Berufung.">

  <!-- HERO — Full-screen cinematic -->
  <section class="relative h-screen min-h-[600px] flex flex-col justify-end overflow-hidden -mt-16">

    <!-- Background image -->
    <img
      src="/assets/atnovo-hero-people.png"
      alt="Atnovo Beratung"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />

    <!-- Layered overlays: subtle top vignette + heavy bottom gradient -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#071625]/92 via-[#071625]/40 to-[#071625]/10 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#071625]/30 to-transparent pointer-events-none"></div>

    <!-- Content — anchored bottom-left -->
    <div class="relative max-w-7xl mx-auto px-5 lg:px-8 w-full pb-14 lg:pb-20">

      <!-- Label -->
      <div class="fade-up inline-flex items-center gap-2 mb-6">
        <span class="w-8 h-px bg-[#087889]"></span>
        <span class="text-xs font-semibold text-[#76C6C7] uppercase tracking-[0.2em]">Digital Consulting</span>
      </div>

      <!-- Main headline -->
      <h1 class="fade-up delay-1 font-display leading-none tracking-tight mb-6">
        <span class="block text-[clamp(3.5rem,10vw,8.5rem)] leading-[0.92]">
          <span class="font-light text-white/55">at</span><span class="font-extrabold text-white">NOVO</span>
        </span>
        <span class="block text-[clamp(1.6rem,4.5vw,3.8rem)] text-white/60 font-light tracking-[0.06em] mt-3">Digital Consulting</span>
      </h1>

      <!-- Tagline + CTA row -->
      <div class="fade-up delay-2 flex flex-col sm:flex-row sm:items-end gap-6 sm:gap-12">
        <p class="text-base sm:text-lg text-white/60 max-w-sm leading-relaxed">
          Digitale Lösungen, die dein Business voranbringen — ohne Technik-Stress.
        </p>
        <div class="flex gap-3 flex-shrink-0">
          <a href="/kontakt" class="px-6 py-3 bg-[#087889] text-white font-semibold rounded-full hover:bg-[#005F70] transition-all hover:shadow-xl text-sm whitespace-nowrap">
            Jetzt starten →
          </a>
          <a href="/leistungen" class="px-6 py-3 bg-white/10 backdrop-blur-sm text-white font-medium rounded-full hover:bg-white/20 transition-all text-sm border border-white/20 whitespace-nowrap">
            Leistungen
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-6 right-8 hidden lg:flex flex-col items-center gap-2 opacity-40">
      <span class="text-[10px] text-white uppercase tracking-widest" style="writing-mode:vertical-rl">Scroll</span>
      <div class="w-px h-12 bg-white/50 relative overflow-hidden">
        <div class="w-full bg-white animate-[scrollline_1.8s_ease-in-out_infinite]" style="height:40%;animation:scrollline 1.8s ease-in-out infinite"></div>
      </div>
    </div>
  </section>

  <style>
    @keyframes scrollline {
      0%   { transform: translateY(-100%); }
      100% { transform: translateY(250%); }
    }
  </style>

  <!-- ZIELGRUPPEN TEASER -->
  <section class="bg-[#F7F9FC] py-24">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="fade-up text-center mb-14">
        <p class="text-xs font-semibold text-[#087889] uppercase tracking-widest mb-3">Für wen sind wir da?</p>
        <h2 class="font-display text-4xl lg:text-5xl font-bold text-[#0C1628] tracking-tight">Zwei Welten. Eine Lösung.</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- E-Commerce Card -->
        <a href="/ecommerce" class="card-lift group relative bg-white rounded-3xl p-8 lg:p-10 border border-gray-100 overflow-hidden block">
          <div class="absolute top-0 right-0 w-48 h-48 bg-[#087889]/6 rounded-full -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
          <div class="relative">
            <div class="w-12 h-12 bg-[#0C1628] rounded-2xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
            </div>
            <h3 class="font-display text-2xl font-bold text-[#0C1628] mb-3">Für E-Commerce</h3>
            <p class="text-[#4B5563] leading-relaxed mb-6">
              Mehr Umsatz, weniger manuelle Arbeit. Wir automatisieren deinen Kundenservice, optimieren deinen Shop für Google und sorgen dafür, dass Bestellungen und Anfragen wie am Schnürchen laufen.
            </p>
            <span class="inline-flex items-center gap-2 text-sm font-semibold text-[#0C1628] group-hover:text-[#087889] transition-colors">
              Mehr erfahren →
            </span>
          </div>
        </a>

        <!-- Praxis Card -->
        <a href="/praxis" class="card-lift group relative bg-[#0C1628] rounded-3xl p-8 lg:p-10 overflow-hidden block">
          <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#087889]/8 rounded-full translate-y-1/2 -translate-x-1/2 pointer-events-none"></div>
          <div class="relative">
            <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
            </div>
            <h3 class="font-display text-2xl font-bold text-white mb-3">Für Praxen & Berater</h3>
            <p class="text-[#9CA3AF] leading-relaxed mb-6">
              Deine Energie gehört deinen Klienten — nicht der Technik. Wir richten deine digitale Präsenz ein, automatisieren Terminbuchungen und sorgen dafür, dass neue Klienten dich finden.
            </p>
            <span class="inline-flex items-center gap-2 text-sm font-semibold text-[#087889]">
              Mehr erfahren →
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- SERVICES OVERVIEW -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="fade-up text-center mb-14">
        <p class="text-xs font-semibold text-[#087889] uppercase tracking-widest mb-3">Was wir tun</p>
        <h2 class="font-display text-4xl lg:text-5xl font-bold text-[#0C1628] tracking-tight mb-4">Alles aus einer Hand.</h2>
        <p class="text-[#4B5563] max-w-xl mx-auto">Kein Wirrwarr aus verschiedenen Anbietern. Wir kümmern uns um alles — von der ersten Idee bis zum laufenden Betrieb.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <!-- Service 1: Chatbot -->
        <div class="fade-up card-lift bg-[#F7F9FC] rounded-2xl p-7 border border-transparent hover:border-[#087889]/20 transition-colors" id="chatbot">
          <div class="w-10 h-10 bg-[#087889]/15 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[#0C1628] mb-2">KI-Assistent</h3>
          <p class="text-sm text-[#6B7280] leading-relaxed">Dein digitaler Mitarbeiter, der rund um die Uhr Fragen beantwortet, Leads sammelt und Kunden betreut.</p>
        </div>

        <!-- Service 2: Telefonie -->
        <div class="fade-up delay-1 card-lift bg-[#F7F9FC] rounded-2xl p-7 border border-transparent hover:border-[#087889]/20 transition-colors" id="telefonie">
          <div class="w-10 h-10 bg-[#087889]/15 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[#0C1628] mb-2">KI-Telefonie</h3>
          <p class="text-sm text-[#6B7280] leading-relaxed">Dein Telefon nimmt automatisch an — freundlich, kompetent, rund um die Uhr. Voicebot-Technologie, die beeindruckt.</p>
        </div>

        <!-- Service 3: E-Mail -->
        <div class="fade-up delay-2 card-lift bg-[#F7F9FC] rounded-2xl p-7 border border-transparent hover:border-[#087889]/20 transition-colors">
          <div class="w-10 h-10 bg-[#087889]/15 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[#0C1628] mb-2">Professionelle E-Mail</h3>
          <p class="text-sm text-[#6B7280] leading-relaxed">Deine eigene Unternehmens-E-Mail-Adresse — seriös, zuverlässig und komplett eingerichtet.</p>
        </div>

        <!-- Service 4: Terminplanung -->
        <div class="fade-up card-lift bg-[#F7F9FC] rounded-2xl p-7 border border-transparent hover:border-[#087889]/20 transition-colors" id="termine">
          <div class="w-10 h-10 bg-[#087889]/15 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[#0C1628] mb-2">Online-Terminbuchung</h3>
          <p class="text-sm text-[#6B7280] leading-relaxed">Kunden buchen selbst — tag und nacht. Kein Telefonieren, keine Doppelbuchungen, keine verpassten Anfragen.</p>
        </div>

        <!-- Service 5: Website -->
        <div class="fade-up delay-1 card-lift bg-[#0C1628] rounded-2xl p-7 border border-transparent" id="website">
          <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-white mb-2">Website-Erstellung</h3>
          <p class="text-sm text-[#9CA3AF] leading-relaxed">Dein professionelles digitales Zuhause — modern, schnell und so gebaut, dass Google dich findet.</p>
        </div>

        <!-- Service 6: Online Marketing -->
        <div class="fade-up delay-2 card-lift bg-[#F7F9FC] rounded-2xl p-7 border border-transparent hover:border-[#087889]/20 transition-colors" id="marketing">
          <div class="w-10 h-10 bg-[#087889]/15 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[#0C1628] mb-2">Online Marketing</h3>
          <p class="text-sm text-[#6B7280] leading-relaxed">Damit dich die richtigen Menschen finden. Wir sorgen dafür, dass deine Zielgruppe auf dich aufmerksam wird.</p>
        </div>

        <!-- Service 7: Social Media -->
        <div class="fade-up card-lift bg-[#F7F9FC] rounded-2xl p-7 border border-transparent hover:border-[#087889]/20 transition-colors">
          <div class="w-10 h-10 bg-[#087889]/15 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[#0C1628] mb-2">Social Media</h3>
          <p class="text-sm text-[#6B7280] leading-relaxed">Deine Präsenz auf Instagram, LinkedIn & Co. — ohne dass du selbst täglich posten musst. Social Media Agentur, die liefert.</p>
        </div>

        <!-- Service 8: Google Ads -->
        <div class="fade-up delay-1 card-lift bg-[#F7F9FC] rounded-2xl p-7 border border-transparent hover:border-[#087889]/20 transition-colors">
          <div class="w-10 h-10 bg-[#087889]/15 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-[#087889]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[#0C1628] mb-2">Google Ads (SEA)</h3>
          <p class="text-sm text-[#6B7280] leading-relaxed">Sofort auf Seite 1 bei Google — genau dann, wenn deine Kunden suchen. Kein Streuverlust, maximale Wirkung.</p>
        </div>

        <!-- Service 9: SEO -->
        <div class="fade-up delay-2 card-lift bg-[#087889] rounded-2xl p-7" id="seo">
          <div class="w-10 h-10 bg-[#0C1628]/15 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-[#0C1628]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-[#0C1628] mb-2">SEO-Agentur</h3>
          <p class="text-sm text-[#0C1628]/70 leading-relaxed">Langfristig bei Google gefunden werden — ohne jeden Monat fürs Klicken zu bezahlen. Nachhaltige Sichtbarkeit.</p>
        </div>

      </div>

      <div class="fade-up text-center mt-10">
        <a href="/leistungen" class="inline-flex items-center gap-2 text-sm font-semibold text-[#0C1628] border-b-2 border-[#087889] pb-0.5 hover:text-[#087889] transition-colors">
          Alle Leistungen im Detail →
        </a>
      </div>
    </div>
  </section>

  <!-- WIE ES FUNKTIONIERT -->
  <section class="bg-[#0C1628] py-24">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="fade-up text-center mb-16">
        <p class="text-xs font-semibold text-[#087889] uppercase tracking-widest mb-3">Unser Prozess</p>
        <h2 class="font-display text-4xl lg:text-5xl font-bold text-white tracking-tight">In drei Schritten digital.</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="fade-up text-center">
          <div class="w-14 h-14 bg-[#087889]/15 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="font-display text-xl font-bold text-[#087889]">01</span>
          </div>
          <h3 class="font-display text-xl font-bold text-white mb-3">Kostenlos beraten</h3>
          <p class="text-[#9CA3AF] text-sm leading-relaxed">Wir hören zu und verstehen, wo dein Business gerade steht. Kein Verkaufsgespräch — ehrliche Einschätzung, was dir wirklich hilft.</p>
        </div>
        <div class="fade-up delay-2 text-center">
          <div class="w-14 h-14 bg-[#087889]/15 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="font-display text-xl font-bold text-[#087889]">02</span>
          </div>
          <h3 class="font-display text-xl font-bold text-white mb-3">Wir richten ein</h3>
          <p class="text-[#9CA3AF] text-sm leading-relaxed">Du lehnst dich zurück — wir kümmern uns um die Umsetzung. Schnell, professionell und ohne dass du Technik-Kram lernen musst.</p>
        </div>
        <div class="fade-up delay-4 text-center">
          <div class="w-14 h-14 bg-[#087889]/15 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="font-display text-xl font-bold text-[#087889]">03</span>
          </div>
          <h3 class="font-display text-xl font-bold text-white mb-3">Du konzentrierst dich</h3>
          <p class="text-[#9CA3AF] text-sm leading-relaxed">Auf das, was du wirklich liebst: deine Kunden, dein Produkt, deine Berufung. Wir halten den Rest am Laufen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="fade-up bg-[#F7F9FC] rounded-3xl p-10 lg:p-16 text-center border border-gray-100">
        <p class="text-xs font-semibold text-[#087889] uppercase tracking-widest mb-4">Bereit für den nächsten Schritt?</p>
        <h2 class="font-display text-4xl lg:text-5xl font-bold text-[#0C1628] tracking-tight mb-5">
          Lass uns gemeinsam<br/>loslegen.
        </h2>
        <p class="text-[#4B5563] mb-8 max-w-md mx-auto">Erstes Gespräch kostenlos und unverbindlich. Wir schauen gemeinsam, welche digitalen Lösungen für dich den größten Unterschied machen.</p>
        <a href="/kontakt" class="inline-flex items-center gap-2 px-8 py-4 bg-[#0C1628] text-white font-semibold rounded-full hover:bg-[#1a2d50] transition-all hover:shadow-xl text-sm">
          Kostenlos anfragen →
        </a>
      </div>
    </div>
  </section>

</Layout>
