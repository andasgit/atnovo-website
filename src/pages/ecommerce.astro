---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Für E-Commerce" description="Digitale Lösungen für Online-Shops: Automatisierung, KI-Kundenservice, SEO, Google Ads und mehr. atNOVO GmbH.">

  <!-- Hero -->
  <section class="relative py-24 lg:py-32 overflow-hidden bg-[#0C1628]">
    <div class="absolute top-0 right-0 w-96 h-96 bg-[#00C896]/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="max-w-2xl">
        <div class="fade-up inline-flex items-center gap-2 px-4 py-1.5 bg-[#00C896]/15 border border-[#00C896]/25 rounded-full mb-8">
          <svg class="w-3.5 h-3.5 text-[#00C896]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          <span class="text-xs font-semibold text-[#00C896] tracking-wide">Lösungen für E-Commerce</span>
        </div>
        <h1 class="fade-up delay-1 font-display text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6">
          Mehr Umsatz.<br/>Weniger Aufwand.
        </h1>
        <p class="fade-up delay-2 text-lg text-[#9CA3AF] leading-relaxed mb-10 max-w-xl">
          Dein Online-Shop soll verkaufen — nicht deine Zeit fressen. Wir automatisieren deinen Kundenservice, sorgen für mehr Sichtbarkeit bei Google und helfen dir, aus Besuchern Käufer zu machen.
        </p>
        <div class="fade-up delay-3 flex flex-wrap gap-4">
          <a href="/kontakt" class="px-7 py-3.5 bg-[#00C896] text-[#0C1628] font-bold rounded-full hover:bg-[#00b886] transition-all hover:shadow-xl text-sm">
            Kostenlos beraten lassen →
          </a>
          <a href="/leistungen" class="px-7 py-3.5 bg-white/10 text-white font-semibold rounded-full hover:bg-white/20 transition-all text-sm">
            Alle Leistungen
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Schmerzpunkte -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="fade-up text-center mb-14">
        <p class="text-xs font-semibold text-[#00956E] uppercase tracking-widest mb-3">Kennst du das?</p>
        <h2 class="font-display text-4xl font-bold text-[#0C1628] tracking-tight">Die größten Zeitfresser<br/>im E-Commerce.</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { problem: 'Immer dieselben Kunden-Fragen beantworten', solution: 'KI-Assistent antwortet automatisch — 24/7' },
          { problem: 'Anrufe die dich aus der Arbeit reißen', solution: 'Voicebot nimmt an und leitet weiter' },
          { problem: 'Google findet deinen Shop nicht', solution: 'SEO-Agentur bringt dich nach oben' },
          { problem: 'Werbung die nichts bringt', solution: 'Google Ads mit messbaren Ergebnissen' },
          { problem: 'Social Media bleibt liegen', solution: 'Wir übernehmen als Social Media Agentur' },
          { problem: 'Kein Zeit für alles', solution: 'atNOVO übernimmt den digitalen Betrieb' },
        ].map((item, i) => (
          <div class={`fade-up rounded-2xl p-6 border ${i % 2 === 0 ? 'bg-[#F7F9FC] border-gray-100' : 'bg-white border-gray-100'}`}>
            <div class="flex items-start gap-3 mb-4">
              <span class="text-red-400 mt-0.5">✗</span>
              <p class="text-sm text-[#6B7280] line-through">{item.problem}</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[#00C896] mt-0.5 font-bold">✓</span>
              <p class="text-sm font-semibold text-[#0C1628]">{item.solution}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Unsere Lösungen für E-Commerce -->
  <section class="py-20 bg-[#F7F9FC]">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="fade-up text-center mb-14">
        <p class="text-xs font-semibold text-[#00956E] uppercase tracking-widest mb-3">Was wir konkret tun</p>
        <h2 class="font-display text-4xl font-bold text-[#0C1628] tracking-tight">Digitale Lösungen<br/>die deinen Shop voranbringen.</h2>
      </div>

      <div class="space-y-5">
        {[
          {
            title: 'KI-Kundenservice, der niemals schläft',
            desc: 'Ein intelligenter Assistent beantwortet Fragen zu Lieferzeiten, Retouren, Produkten und mehr — sofort, rund um die Uhr. Dein Support-Aufwand sinkt, die Kundenzufriedenheit steigt.',
            tag: 'Automatisierung',
          },
          {
            title: 'SEO für mehr organischen Traffic',
            desc: 'Als SEO-Agentur sorgen wir dafür, dass dein Shop bei relevanten Suchanfragen auf Seite 1 erscheint. Mehr Besucher, mehr Umsatz — ohne laufende Werbekosten.',
            tag: 'SEO-Agentur',
          },
          {
            title: 'Google Ads mit echtem ROI',
            desc: 'Wir schalten gezielte Google Ads, die genau dann ausgespielt werden, wenn Kunden kaufbereit sind. Kein verschwendetes Budget, klare Erfolgsmessung.',
            tag: 'Google Ads',
          },
          {
            title: 'Website-Erstellung & Shop-Optimierung',
            desc: 'Ein Shop der gut aussieht aber nicht konvertiert, bringt nichts. Wir optimieren dein Design, die Ladezeit und die Nutzerführung — damit Besucher zu Käufern werden.',
            tag: 'Website',
          },
        ].map(item => (
          <div class="fade-up flex flex-col sm:flex-row gap-5 bg-white rounded-2xl p-7 border border-gray-100 card-lift">
            <div class="flex-1">
              <span class="inline-block px-3 py-1 bg-[#00C896]/10 text-[#00956E] text-xs font-semibold rounded-full mb-3">{item.tag}</span>
              <h3 class="font-display text-xl font-bold text-[#0C1628] mb-2">{item.title}</h3>
              <p class="text-sm text-[#4B5563] leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-[#00C896]">
    <div class="max-w-3xl mx-auto px-5 lg:px-8 text-center fade-up">
      <h2 class="font-display text-4xl font-bold text-[#0C1628] mb-4">Bereit, deinen Shop auf das nächste Level zu heben?</h2>
      <p class="text-[#0C1628]/70 mb-8">Lass uns in einem kostenlosen Gespräch schauen, was deinem Shop am meisten bringt.</p>
      <a href="/kontakt" class="inline-flex items-center gap-2 px-8 py-4 bg-[#0C1628] text-white font-bold rounded-full hover:bg-[#1a2d50] transition-all text-sm">
        Jetzt kostenlos anfragen →
      </a>
    </div>
  </section>

</Layout>
