---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Impressum" description="Impressum der atNOVO GmbH – Angaben gemäß § 5 DDG.">

  <section class="py-20 lg:py-28 bg-[#F7F9FC] min-h-[80vh]">
    <div class="max-w-3xl mx-auto px-5 lg:px-8">
      <p class="text-xs font-semibold text-[#00956E] uppercase tracking-widest mb-4">Rechtliches</p>
      <h1 class="font-display text-4xl lg:text-5xl font-extrabold text-[#0C1628] tracking-tight mb-10">Impressum</h1>

      <div class="prose-style space-y-8 text-[#374151]">

        <div>
          <h2 class="font-display text-xl font-bold text-[#0C1628] mb-3">Angaben gemäß § 5 DDG</h2>
          <p class="leading-relaxed">
            atNOVO GmbH — Digital Consulting<br />
            Harksheider Weg 68<br />
            25451 Quickborn
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-bold text-[#0C1628] mb-3">Vertretungsberechtigter Geschäftsführer</h2>
          <p class="leading-relaxed">Andreas Jan Jaszczuk (M.Sc.)</p>
        </div>

        <div>
          <h2 class="font-display text-xl font-bold text-[#0C1628] mb-3">Kontakt</h2>
          <p class="leading-relaxed">
            E-Mail: <a href="mailto:info@atnovo.com" class="text-[#00956E] hover:underline">info@atnovo.com</a><br />
            Telefon: <a href="tel:+494060778174" class="text-[#00956E] hover:underline">+49 (0) 40 60778174</a>
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-bold text-[#0C1628] mb-3">Registerangaben</h2>
          <p class="leading-relaxed">
            Handelsregisternummer: HRB 128528<br />
            Registergericht: Amtsgericht Hamburg
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-bold text-[#0C1628] mb-3">Umsatzsteuer</h2>
          <p class="leading-relaxed">
            Umsatzsteuer-Identifikationsnummer gemäß § 27 a UStG:<br />
            DE277280694
          </p>
          <p class="leading-relaxed mt-2">Steuernummer: 18/297/27923</p>
        </div>

        <div>
          <h2 class="font-display text-xl font-bold text-[#0C1628] mb-3">Verpackungsregister (LUCID)</h2>
          <p class="leading-relaxed">Registrierungsnummer: DE2185631033869</p>
        </div>

      </div>
    </div>
  </section>

</Layout>
