---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'chatbot',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>`,
    title: 'KI-Assistent (Chatbot)',
    tagline: 'Dein digitaler Mitarbeiter.',
    desc: 'Ein KI-Assistent, der rund um die Uhr auf deiner Website oder in deinem Shop antwortet. Er beantwortet Fragen, qualifiziert Interessenten, bucht Termine und gibt niemals Feierabend. Kunden bekommen sofort eine Antwort — du wirst nicht mehr unterbrochen.',
    bullets: ['24/7 verfügbar', 'Sofortige Antworten', 'Lead-Qualifizierung', 'Mehrsprachig möglich'],
    dark: false,
  },
  {
    id: 'telefonie',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>`,
    title: 'KI-Telefonie & Voicebot',
    tagline: 'Kein verpasster Anruf mehr.',
    desc: 'Unser Voicebot nimmt an, wenn du nicht kannst — und klingt dabei wie ein echter Mensch. Er nimmt Nachrichten entgegen, beantwortet Standardfragen, leitet weiter und sendet dir eine Zusammenfassung. Perfekt für Praxen, Berater und kleine Shops.',
    bullets: ['Kein verpasster Anruf', 'Natürliche Sprache', 'Nachrichtenweiterleitung', 'Individuelle Konfiguration'],
    dark: true,
  },
  {
    id: 'email',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
    title: 'Professionelle E-Mail',
    tagline: 'Seriös auftreten von Anfang an.',
    desc: 'name@deinunternehmen.de macht mehr Eindruck als eine Gmail-Adresse. Wir richten dein professionelles E-Mail-System ein — mit allem, was dazugehört: Spam-Schutz, Signaturen, mehrere Postfächer für dein Team.',
    bullets: ['Eigene Domain', 'Team-Postfächer', 'Spam-Schutz', 'Mobile Einrichtung'],
    dark: false,
  },
  {
    id: 'termine',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>`,
    title: 'Online-Terminbuchung',
    tagline: 'Kunden buchen selbst — du tust nichts.',
    desc: 'Schluss mit dem Telefonieren und dem manuellen Eintragen von Terminen. Kunden buchen selbst, bekommen automatische Erinnerungen und du siehst alles in einem Kalender. Funktioniert für Praxen, Coaches, Berater und mehr.',
    bullets: ['Automatische Bestätigungen', 'Erinnerungs-E-Mails', 'Kalender-Synchronisation', 'Keine Doppelbuchungen'],
    dark: false,
  },
  {
    id: 'website',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>`,
    title: 'Website-Erstellung',
    tagline: 'Dein digitales Zuhause.',
    desc: 'Eine professionelle Website, die Besucher in Kunden verwandelt. Wir planen, gestalten und bauen sie — schnell, mobil-optimiert und SEO-ready. Du weißt immer, was gerade passiert, ohne selbst coden zu müssen.',
    bullets: ['Responsive Design', 'SEO-optimiert', 'Schnell & sicher', 'Einfache Pflege'],
    dark: true,
  },
  {
    id: 'marketing',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/>`,
    title: 'Online Marketing',
    tagline: 'Damit dich die Richtigen finden.',
    desc: 'Online Marketing ist mehr als Werbung schalten. Wir entwickeln eine Strategie, die zu deinem Business passt — welche Kanäle sich lohnen, wie du deine Zielgruppe erreichst und wie du messbar mehr Anfragen bekommst.',
    bullets: ['Strategie-Entwicklung', 'Kanal-Auswahl', 'Kampagnen-Management', 'Monatliches Reporting'],
    dark: false,
  },
  {
    id: 'social',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/>`,
    title: 'Social Media',
    tagline: 'Sichtbar, ohne täglich zu posten.',
    desc: 'Wir übernehmen deine Social-Media-Präsenz auf Instagram, LinkedIn, Facebook & Co. Von der Strategie über die Inhalte bis zur Community-Pflege — du bekommst professionelle Betreuung als Social Media Agentur aus einer Hand.',
    bullets: ['Content-Erstellung', 'Redaktionsplan', 'Community Management', 'Erfolgsmessung'],
    dark: false,
  },
  {
    id: 'sea',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
    title: 'Google Ads (SEA)',
    tagline: 'Sofort auf Seite 1.',
    desc: 'Wenn deine Kunden nach dir suchen, wirst du gefunden — sofort. Wir richten deine Google Ads Kampagnen ein, optimieren sie laufend und achten darauf, dass jeder Euro Werbebudget wirkt. Als Google Ads Agentur arbeiten wir nur mit messbaren Ergebnissen.',
    bullets: ['Professionelle Kampagnen', 'Budget-Kontrolle', 'Laufende Optimierung', 'Transparentes Reporting'],
    dark: false,
  },
  {
    id: 'seo',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>`,
    title: 'SEO-Agentur',
    tagline: 'Langfristig bei Google gefunden werden.',
    desc: 'Als SEO-Agentur sorgen wir dafür, dass deine Website organisch bei Google rankt — nachhaltig und ohne monatliche Klick-Kosten. Wir optimieren Texte, Struktur und technische Details, damit dich deine Zielgruppe genau dann findet, wenn sie sucht.',
    bullets: ['Keyword-Analyse', 'OnPage-Optimierung', 'Lokale SEO', 'Monatliche Reports'],
    dark: true,
  },
];
---

<Layout title="Leistungen" description="Alle digitalen Lösungen von atNOVO: KI-Assistent, Voicebot, Website-Erstellung, SEO, Online Marketing, Social Media und mehr.">

  <!-- Hero -->
  <section class="py-20 lg:py-28 bg-[#F7F9FC]">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 text-center">
      <p class="fade-up text-xs font-semibold text-[#00956E] uppercase tracking-widest mb-4">Was wir anbieten</p>
      <h1 class="fade-up delay-1 font-display text-5xl lg:text-6xl font-extrabold text-[#0C1628] tracking-tight mb-6">
        Alle Leistungen.<br/>Eine Agentur.
      </h1>
      <p class="fade-up delay-2 text-lg text-[#4B5563] max-w-2xl mx-auto">
        Kein Wirrwarr aus verschiedenen Anbietern. Bei atNOVO bekommst du alles aus einer Hand — von der ersten digitalen Lösung bis zur laufenden Betreuung.
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 space-y-8">
      {services.map((s, i) => (
        <div id={s.id} class={`fade-up card-lift rounded-3xl p-8 lg:p-12 border ${s.dark ? 'bg-[#0C1628] border-white/5' : 'bg-[#F7F9FC] border-gray-100'}`}>
          <div class="flex flex-col lg:flex-row lg:items-start gap-8">
            <div class={`w-14 h-14 rounded-2xl flex-shrink-0 flex items-center justify-center ${s.dark ? 'bg-white/10' : 'bg-[#00C896]/15'}`}>
              <svg class={`w-7 h-7 ${s.dark ? 'text-[#00C896]' : 'text-[#00956E]'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={s.icon}></svg>
            </div>
            <div class="flex-1">
              <p class={`text-xs font-semibold uppercase tracking-widest mb-2 ${s.dark ? 'text-[#00C896]' : 'text-[#00956E]'}`}>{s.tagline}</p>
              <h2 class={`font-display text-2xl lg:text-3xl font-bold mb-4 ${s.dark ? 'text-white' : 'text-[#0C1628]'}`}>{s.title}</h2>
              <p class={`leading-relaxed mb-6 max-w-2xl ${s.dark ? 'text-[#9CA3AF]' : 'text-[#4B5563]'}`}>{s.desc}</p>
              <div class="flex flex-wrap gap-2">
                {s.bullets.map(b => (
                  <span class={`px-3 py-1 rounded-full text-xs font-medium ${s.dark ? 'bg-white/10 text-white/80' : 'bg-white text-[#374151] border border-gray-200'}`}>
                    ✓ {b}
                  </span>
                ))}
              </div>
            </div>
            <div class="flex-shrink-0">
              <a href="/kontakt" class={`inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold transition-all ${s.dark ? 'bg-[#00C896] text-[#0C1628] hover:bg-[#00b886]' : 'bg-[#0C1628] text-white hover:bg-[#1a2d50]'}`}>
                Anfragen →
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-[#F7F9FC]">
    <div class="max-w-3xl mx-auto px-5 lg:px-8 text-center fade-up">
      <h2 class="font-display text-3xl lg:text-4xl font-bold text-[#0C1628] mb-4">Nicht sicher, wo du anfangen sollst?</h2>
      <p class="text-[#4B5563] mb-8">Kein Problem. Wir analysieren kostenlos, was deinem Business am meisten bringt — und machen einen konkreten Vorschlag.</p>
      <a href="/kontakt" class="inline-flex items-center gap-2 px-8 py-4 bg-[#0C1628] text-white font-semibold rounded-full hover:bg-[#1a2d50] transition-all hover:shadow-xl text-sm">
        Kostenlose Beratung →
      </a>
    </div>
  </section>

</Layout>
