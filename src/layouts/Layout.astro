---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'atNOVO GmbH',
  description = 'Digitale Lösungen für E-Commerce und Praxen. Chatbots, KI-Telefonie, Websites, SEO, Online Marketing – damit du dich auf deine Berufung konzentrieren kannst.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <title>{title === 'atNOVO GmbH' ? 'atNOVO GmbH – Digitale Lösungen' : `${title} – atNOVO GmbH`}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;900&family=Syne:wght@400;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
</head>
<body class="bg-white text-[#0D1117] antialiased">

  <!-- Navigation -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="flex items-center justify-between h-16">

        <!-- Logo -->
        <a href="/" class="flex items-center" aria-label="atNOVO GmbH – Startseite">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 480 120" class="h-9 w-auto" aria-hidden="true">
            <text x="22" y="88" font-family="'Poppins','Segoe UI',Arial,sans-serif" xml:space="preserve">
              <tspan font-size="48" font-weight="700" fill="#00FF41">at</tspan><tspan font-size="78" font-weight="900" fill="#1E3A5F" letter-spacing="-1">NOVO</tspan>
            </text>
          </svg>
        </a>

        <!-- Desktop links -->
        <div class="hidden md:flex items-center gap-7">
          <a href="/leistungen" class="text-sm font-medium text-[#4B5563] hover:text-[#0C1628] transition-colors">Leistungen</a>
          <a href="/ecommerce" class="text-sm font-medium text-[#4B5563] hover:text-[#0C1628] transition-colors">Für E-Commerce</a>
          <a href="/praxis" class="text-sm font-medium text-[#4B5563] hover:text-[#0C1628] transition-colors">Für Praxen</a>
          <a href="/ueber-uns" class="text-sm font-medium text-[#4B5563] hover:text-[#0C1628] transition-colors">Über uns</a>
        </div>

        <div class="hidden md:flex items-center">
          <a href="/kontakt" class="px-5 py-2 bg-[#0C1628] text-white text-sm font-semibold rounded-full hover:bg-[#1a2d50] transition-all hover:shadow-lg">
            Jetzt starten →
          </a>
        </div>

        <!-- Burger -->
        <button id="burger" class="md:hidden p-2 text-[#0C1628]" aria-label="Menü">
          <svg id="burger-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-nav" class="hidden md:hidden bg-white border-t border-gray-100 px-5 py-5 space-y-3">
      <a href="/leistungen" class="block text-sm font-medium text-[#374151] py-2">Leistungen</a>
      <a href="/ecommerce" class="block text-sm font-medium text-[#374151] py-2">Für E-Commerce</a>
      <a href="/praxis" class="block text-sm font-medium text-[#374151] py-2">Für Praxen & Berater</a>
      <a href="/ueber-uns" class="block text-sm font-medium text-[#374151] py-2">Über uns</a>
      <a href="/kontakt" class="block mt-3 text-center px-5 py-2.5 bg-[#0C1628] text-white text-sm font-semibold rounded-full">Jetzt starten →</a>
    </div>
  </nav>

  <main class="pt-16">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-[#0C1628] text-white">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-10 lg:gap-16">
        <div class="col-span-2 md:col-span-1">
          <div class="mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 480 120" class="h-8 w-auto" aria-hidden="true">
              <text x="22" y="88" font-family="'Poppins','Segoe UI',Arial,sans-serif" xml:space="preserve">
                <tspan font-size="48" font-weight="700" fill="#00FF41">at</tspan><tspan font-size="78" font-weight="900" fill="#FFFFFF" letter-spacing="-1">NOVO</tspan>
              </text>
            </svg>
          </div>
          <p class="text-sm text-[#9CA3AF] leading-relaxed max-w-xs">
            Digitale Lösungen, die dein Business voranbringen — ohne dass du selbst Technik-Profi sein musst.
          </p>
        </div>

        <div>
          <h3 class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-5">Leistungen</h3>
          <ul class="space-y-3">
            <li><a href="/leistungen#chatbot" class="text-sm text-[#9CA3AF] hover:text-white transition-colors">KI-Assistent</a></li>
            <li><a href="/leistungen#telefonie" class="text-sm text-[#9CA3AF] hover:text-white transition-colors">KI-Telefonie</a></li>
            <li><a href="/leistungen#website" class="text-sm text-[#9CA3AF] hover:text-white transition-colors">Website</a></li>
            <li><a href="/leistungen#marketing" class="text-sm text-[#9CA3AF] hover:text-white transition-colors">Online Marketing</a></li>
            <li><a href="/leistungen#seo" class="text-sm text-[#9CA3AF] hover:text-white transition-colors">SEO & Google Ads</a></li>
          </ul>
        </div>

        <div>
          <h3 class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-5">Unternehmen</h3>
          <ul class="space-y-3">
            <li><a href="/ecommerce" class="text-sm text-[#9CA3AF] hover:text-white transition-colors">Für E-Commerce</a></li>
            <li><a href="/praxis" class="text-sm text-[#9CA3AF] hover:text-white transition-colors">Für Praxen & Berater</a></li>
            <li><a href="/ueber-uns" class="text-sm text-[#9CA3AF] hover:text-white transition-colors">Über uns</a></li>
            <li><a href="/kontakt" class="text-sm text-[#9CA3AF] hover:text-white transition-colors">Kontakt</a></li>
          </ul>
        </div>

        <div>
          <h3 class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-5">Kontakt</h3>
          <p class="text-sm text-[#9CA3AF] mb-1">Harksheider Weg 68<br />25451 Quickborn</p>
          <a href="mailto:info@atnovo.com" class="text-sm text-[#9CA3AF] hover:text-white transition-colors block mb-1">info@atnovo.com</a>
          <a href="tel:+494060778174" class="text-sm text-[#9CA3AF] hover:text-white transition-colors block">+49 (0) 40 60778174</a>
          <a href="/kontakt" class="inline-flex items-center gap-2 mt-5 px-5 py-2.5 bg-[#00C896] text-[#0C1628] text-sm font-bold rounded-full hover:bg-[#00b886] transition-colors">
            Jetzt anfragen →
          </a>
        </div>
      </div>

      <div class="mt-14 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="text-xs text-[#6B7280]">© 2025 atNOVO GmbH. Alle Rechte vorbehalten.</p>
        <div class="flex gap-6">
          <a href="/impressum" class="text-xs text-[#6B7280] hover:text-white transition-colors">Impressum</a>
          <a href="/datenschutz" class="text-xs text-[#6B7280] hover:text-white transition-colors">Datenschutz</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu
    document.getElementById('burger')?.addEventListener('click', () => {
      document.getElementById('mobile-nav')?.classList.toggle('hidden');
    });

    // Scroll animation
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('is-visible'); }),
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
  </script>
</body>
</html>
